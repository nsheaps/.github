{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill",
      "Glob",
      "Grep",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(gh pr:*)",
      "Bash(just:*)",
      "Bash(yarn:*)",
      "Bash(mise:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "nsheaps-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "nsheaps/ai"
      }
    }
  },
  "enabledPlugins": {
    "todo-sync@nsheaps-claude-plugins": true
  }
}
