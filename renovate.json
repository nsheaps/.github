{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>nsheaps/renovate-config"],
  "packageRules": [
    {
      "matchPackagePatterns": ["*"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": false
    }
  ],
  "github-actions": {
    "enabled": true
  },
  "npm": {
    "enabled": true
  }
}
