{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>nsheaps/renovate-config"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": false,
      "matchPackageNames": [
        "*"
      ]
    }
  ],
  "ansible": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)ansible/.*\\.ya?ml$/"
    ]
  },
  "github-actions": {
    "enabled": true
  },
  "npm": {
    "enabled": true
  },
  "pip_requirements": {
    "enabled": true,
    "managerFilePatterns": [
      "/(^|/)requirements.*\\.txt$/"
    ]
  }
}
